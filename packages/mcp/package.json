{
	"name": "@ecu-explorer/mcp",
	"version": "0.0.1",
	"type": "module",
	"bin": {
		"ecu-mcp": "./dist/index.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./formatters/markdown": {
			"import": "./dist/formatters/markdown.js",
			"types": "./dist/formatters/markdown.d.ts"
		},
		"./formatters/table-formatter": {
			"import": "./dist/formatters/table-formatter.js",
			"types": "./dist/formatters/table-formatter.d.ts"
		},
		"./formatters/table-summary": {
			"import": "./dist/formatters/table-summary.js",
			"types": "./dist/formatters/table-summary.d.ts"
		},
		"./formatters/unit": {
			"import": "./dist/formatters/unit.js",
			"types": "./dist/formatters/unit.d.ts"
		},
		"./formatters/yaml-formatter": {
			"import": "./dist/formatters/yaml-formatter.js",
			"types": "./dist/formatters/yaml-formatter.d.ts"
		},
		"./rom-loader": {
			"import": "./dist/rom-loader.js",
			"types": "./dist/rom-loader.d.ts"
		},
		"./formatters/diagnostics-formatter": {
			"import": "./dist/formatters/diagnostics-formatter.js",
			"types": "./dist/formatters/diagnostics-formatter.d.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"check": "tsc --noEmit"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.1",
		"@ecu-explorer/core": "*",
		"@ecu-explorer/definitions-ecuflash": "*",
		"filtrex": "^3.1.0",
		"js-yaml": "^4.1.0",
		"zod": "^3.25.67"
	},
	"devDependencies": {
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.10.1",
		"typescript": "*"
	}
}
