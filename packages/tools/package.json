{
	"name": "@ecu-explorer/tools",
	"version": "0.0.1",
	"type": "module",
	"description": "CLI tools for ECU Explorer",
	"private": true,
	"scripts": {
		"build": "echo 'No build step required for JS package'",
		"inspect-rom": "node ./inspect-rom.js",
		"rom-info": "node ./rom-info.js",
		"diff-tables": "node ./diff-tables.js",
		"list-tables": "node ./list-tables.js",
		"read-table": "node ./read-table.js",
		"patch-table": "node ./patch-table.js",
		"list-logs": "node ./list-logs.js",
		"read-log": "node ./read-log.js",
		"normalize-log": "node ./normalize-log.js",
		"inspect-device": "node ./inspect-device.js",
		"check": "tsc --noEmit"
	},
	"dependencies": {
		"@ecu-explorer/core": "*",
		"@ecu-explorer/definitions-ecuflash": "*",
		"@ecu-explorer/device": "*",
		"@ecu-explorer/device-transport-openport2": "*",
		"@ecu-explorer/hardware-runtime-node": "*",
		"@ecu-explorer/protocol-obd2": "*",
		"@ecu-explorer/protocol-mut3": "*",
		"@ecu-explorer/protocol-mitsubishi-bootloader": "*",
		"@ecu-explorer/protocol-subaru": "*",
		"@ecu-explorer/protocol-uds": "*",
		"@ecu-explorer/mcp": "*",
		"sade": "^1.8.1",
		"serialport": "^13.0.0"
	},
	"devDependencies": {
		"@types/node": "*"
	}
}
