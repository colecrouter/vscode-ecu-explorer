{
	"name": "@ecu-explorer/definitions-ecuflash",
	"version": "0.0.1",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check": "tsc -p tsconfig.build.json --noEmit",
		"check:test": "tsc -p tsconfig.test.json --noEmit",
		"inspect:rom": "node ./dist/inspect-rom.js",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"test:debug": "vitest --inspect-brk --inspect --single-thread"
	},
	"dependencies": {
		"@ecu-explorer/core": "*",
		"fast-xml-parser": "^5.3.3"
	},
	"devDependencies": {
		"@types/node": "*",
		"typescript": "*",
		"vitest": "*"
	}
}
